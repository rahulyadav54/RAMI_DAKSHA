
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Details about the user including role and progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "parent"] },
        "gradeLevel": { "type": "number" },
        "totalPoints": { "type": "number" },
        "currentStreak": { "type": "number" },
        "lastActiveAt": { "type": "string", "format": "date-time" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["uid", "role"]
    },
    "ReadingSession": {
      "title": "Reading Session",
      "description": "A unit of uploaded content and its AI analysis.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "readingLevel": { "type": "object" },
        "quiz": { "type": "object" },
        "studyGuide": { "type": "object" },
        "flashcards": { "type": "array" },
        "flowchart": { "type": "string" },
        "visualUrl": { "type": "string" }
      }
    },
    "QuizAttempt": {
      "title": "Quiz Attempt",
      "description": "Result of a student taking a quiz.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "type": { "type": "string", "enum": ["standard", "speed", "adaptive"] },
        "score": { "type": "number" },
        "evaluations": { "type": "array" },
        "skillGaps": { "type": "array" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CharacterChat": {
      "title": "Character Chat",
      "description": "Messages exchanged with an AI character.",
      "type": "object",
      "properties": {
        "characterId": { "type": "string" },
        "messages": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "HomeworkTask": {
      "title": "Homework Task",
      "description": "AI-generated tasks based on weak areas.",
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "tasks": { "type": "array" },
        "isCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/ReadingSession" },
      "description": "History of uploaded materials."
    },
    "/users/{userId}/attempts/{attemptId}": {
      "schema": { "$ref": "#/backend/entities/QuizAttempt" },
      "description": "Student quiz results."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": { "$ref": "#/backend/entities/CharacterChat" },
      "description": "Conversations with AI characters."
    },
    "/users/{userId}/homework/{taskId}": {
      "schema": { "$ref": "#/backend/entities/HomeworkTask" },
      "description": "Personalized homework assignments."
    }
  }
}
