
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Details about the user including role and progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "parent"] },
        "gradeLevel": { "type": "number" },
        "totalPoints": { "type": "number" },
        "currentStreak": { "type": "number" },
        "lastActiveAt": { "type": "string", "format": "date-time" },
        "avatarUrl": { "type": "string" },
        "childrenIds": { "type": "array", "items": { "type": "string" } },
        "teacherId": { "type": "string" },
        "classCode": { "type": "string" },
        "approved": { "type": "boolean" }
      },
      "required": ["uid", "role"]
    },
    "ReadingSession": {
      "title": "Reading Session",
      "description": "A unit of uploaded content and its AI analysis.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "readingLevel": { "type": "object" },
        "quiz": { "type": "object" },
        "studyGuide": { "type": "object" },
        "flashcards": { "type": "array" },
        "flowchart": { "type": "string" },
        "visualUrl": { "type": "string" }
      }
    },
    "SkillPractice": {
      "title": "Skill Practice",
      "description": "Record of a foundational skill practice session.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "skillType": { "type": "string", "enum": ["handwriting", "math", "spelling"] },
        "content": { "type": "string" },
        "score": { "type": "number" },
        "feedback": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CharacterInteraction": {
      "title": "Character Interaction",
      "description": "A log of a conversation between a student and an AI character.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "characterName": { "type": "string" },
        "messages": { "type": "array" },
        "comprehensionScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles with role-specific metadata."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/ReadingSession" },
      "description": "History of uploaded materials."
    },
    "/users/{userId}/practice/{practiceId}": {
      "schema": { "$ref": "#/backend/entities/SkillPractice" },
      "description": "Foundation skill practice records."
    },
    "/users/{userId}/interactions/{interactionId}": {
      "schema": { "$ref": "#/backend/entities/CharacterInteraction" },
      "description": "History of AI character conversations."
    }
  }
}
