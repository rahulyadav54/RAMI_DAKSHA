
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Details about the user including role and progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "parent"] },
        "gradeLevel": { "type": "number" },
        "totalPoints": { "type": "number" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["uid", "role"]
    },
    "ReadingSession": {
      "title": "Reading Session",
      "description": "A unit of uploaded content and its AI analysis.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "readingLevel": { "type": "object" },
        "quiz": { "type": "object" },
        "studyGuide": { "type": "object" },
        "flashcards": { "type": "array" },
        "flowchart": { "type": "string" }
      }
    },
    "QuizAttempt": {
      "title": "Quiz Attempt",
      "description": "Result of a student taking a quiz.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "type": { "type": "string", "enum": ["standard", "speed"] },
        "score": { "type": "number" },
        "evaluations": { "type": "array" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Achievement": {
      "title": "Achievement",
      "description": "A badge or milestone reached by a student.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "unlockedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/ReadingSession" },
      "description": "History of uploaded materials and AI tools."
    },
    "/users/{userId}/attempts/{attemptId}": {
      "schema": { "$ref": "#/backend/entities/QuizAttempt" },
      "description": "Student quiz results."
    },
    "/users/{userId}/achievements/{achievementId}": {
      "schema": { "$ref": "#/backend/entities/Achievement" },
      "description": "Badges earned."
    }
  }
}
