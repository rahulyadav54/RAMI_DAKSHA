
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Details about the user including role and progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "parent"] },
        "gradeLevel": { "type": "number" },
        "totalPoints": { "type": "number" },
        "currentStreak": { "type": "number" },
        "lastActiveAt": { "type": "string", "format": "date-time" },
        "avatarUrl": { "type": "string" },
        "childrenIds": { "type": "array", "items": { "type": "string" } },
        "teacherId": { "type": "string" },
        "classCode": { "type": "string" },
        "approved": { "type": "boolean" }
      },
      "required": ["uid", "role"]
    },
    "ReadingSession": {
      "title": "Reading Session",
      "description": "A unit of uploaded content and its AI analysis.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "readingLevel": { "type": "object" },
        "quiz": { "type": "object" },
        "studyGuide": { "type": "object" },
        "flashcards": { "type": "array" },
        "flowchart": { "type": "string" },
        "visualUrl": { "type": "string" }
      }
    },
    "QuizAttempt": {
      "title": "Quiz Attempt",
      "description": "Result of a student taking a quiz.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "studentId": { "type": "string" },
        "type": { "type": "string", "enum": ["standard", "speed", "adaptive"] },
        "score": { "type": "number" },
        "evaluations": { "type": "array" },
        "skillGaps": { "type": "array" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Assessment": {
      "title": "Assessment",
      "description": "A teacher-created assessment assigned to students.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "createdBy": { "type": "string" },
        "assignedTo": { "type": "array", "items": { "type": "string" } },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles with role-specific metadata."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "#/backend/entities/ReadingSession" },
      "description": "History of uploaded materials."
    },
    "/users/{userId}/attempts/{attemptId}": {
      "schema": { "$ref": "#/backend/entities/QuizAttempt" },
      "description": "Student quiz results."
    },
    "/assessments/{assessmentId}": {
      "schema": { "$ref": "#/backend/entities/Assessment" },
      "description": "Global assessment bank created by teachers."
    }
  }
}
